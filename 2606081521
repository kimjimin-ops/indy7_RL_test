def ee_position_w(env: ManagerBasedRLEnv, asset_cfg: SceneEntityCfg) -> torch.Tensor:
    from isaaclab.utils.math import quat_apply
    asset = env.scene[asset_cfg.name]
    ee_pos  = asset.data.body_state_w[:, asset_cfg.body_ids[0], :3]
    ee_quat = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]
    local_offset = torch.tensor([[0.0, 0.0, 0.27]], device=ee_pos.device).expand(ee_pos.shape[0], -1)
    world_offset = quat_apply(ee_quat, local_offset)
    tcp_pos = ee_pos + world_offset
    return tcp_pos - asset.data.root_state_w[:, :3]


def cube_position_w(env: ManagerBasedRLEnv, object_cfg: SceneEntityCfg) -> torch.Tensor:
    """Cube world position relative to robot base."""
    robot = env.scene["robot"]
    cube = env.scene[object_cfg.name]
    return cube.data.root_state_w[:, :3] - robot.data.root_state_w[:, :3]


# 직전 스텝의 큐브 z를 저장하는 버퍼 (변화량 |z_t - z_{t-1}| 계산용)
_prev_cube_z = None


def conditional_cube_lifted(
    env: ManagerBasedRLEnv,
    asset_cfg: SceneEntityCfg,
    object_cfg: SceneEntityCfg,
    distance_threshold: float,
    z_init: float) -> torch.Tensor:
    from isaaclab.utils.math import quat_apply
    """Reward: EE가 큐브에 가까울 때, 큐브를 1cm~10cm 들어올리면 1.0~10.0의 보상 부여"""
    asset = env.scene[asset_cfg.name]
    cube = env.scene[object_cfg.name]

    ee_pos = asset.data.body_state_w[:, asset_cfg.body_ids[0], :3]
    ee_quat = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]
    local_offset = torch.tensor([[0.0, 0.0, 0.27]], device=ee_pos.device).expand(ee_pos.shape[0], -1)
    world_offset = quat_apply(ee_quat, local_offset)
    tcp_pos = ee_pos + world_offset

    cube_pos = cube.data.root_state_w[:, :3]
    distance = torch.norm(tcp_pos - cube_pos, dim=1)
    is_close = distance < distance_threshold

    lift_height = cube_pos[:, 2] - z_init
    is_lifted = lift_height >= 0.01

    lift_reward = torch.clamp(lift_height * 100.0, min=0.0, max=10.0)

    return is_close.float() * is_lifted.float() * lift_reward

def conditional_cube_lifted(
    env: ManagerBasedRLEnv,
    asset_cfg: SceneEntityCfg,
    object_cfg: SceneEntityCfg,
    distance_threshold: float,
    z_init: float,
    target_pos: tuple = (0.4, 0.4, 0.05), # [추가] 목표 위치
    radius: float = 0.1                   # [추가] 반경 기준값
) -> torch.Tensor:
    from isaaclab.utils.math import quat_apply
    """
    Reward: EE가 큐브에 가까울 때 큐브를 들면 보상을 부여하지만,
    목표 반경(radius) 내에 진입하면(Place 영역) 들수록 페널티를 부여.
    """
    asset = env.scene[asset_cfg.name]
    cube = env.scene[object_cfg.name]

    # 1. 엔드 이펙터와 큐브 간의 거리 및 근접 여부 (기존 유지)
    ee_pos = asset.data.body_state_w[:, asset_cfg.body_ids[0], :3]
    ee_quat = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]
    local_offset = torch.tensor([[0.0, 0.0, 0.27]], device=ee_pos.device).expand(ee_pos.shape[0], -1)
    world_offset = quat_apply(ee_quat, local_offset)
    tcp_pos = ee_pos + world_offset

    cube_pos = cube.data.root_state_w[:, :3]
    distance = torch.norm(tcp_pos - cube_pos, dim=1)
    is_close = distance < distance_threshold

    # 2. Lift 높이 기반 기본 보상 계산 (기존 유지)
    lift_height = cube_pos[:, 2] - z_init
    is_lifted = lift_height >= 0.01
    lift_reward = torch.clamp(lift_height * 100.0, min=0.0, max=10.0)

    # ---------------------------------------------------------
    # 3. [신규 추가] 목표점과의 거리 및 반경 내 진입 여부 (C_in)
    # ---------------------------------------------------------
    target_tensor = torch.tensor(target_pos, device=cube_pos.device).expand(cube_pos.shape[0], -1)
    target_distance = torch.norm(cube_pos - target_tensor, dim=1)
    
    # is_inside가 수식의 C_in 역할을 합니다. (True=1.0, False=0.0)
    is_inside = (target_distance < radius).float()

    # 4. 동적 배수(Multiplier) 계산: (1 - 2 * C_in)
    # 밖(0)이면 1.0이 되어 정상 보상, 안(1)이면 -1.0이 되어 페널티로 변환
    dynamic_multiplier = 1.0 - 2.0 * is_inside

    # 5. 최종 결합: (근접 조건) * (들림 조건) * (기본 보상) * (동적 배수)
    final_reward = is_close.float() * is_lifted.float() * lift_reward * dynamic_multiplier

    return final_reward

def pick_and_place_reward(
    env: ManagerBasedRLEnv,
    object_cfg: SceneEntityCfg,
    goal: tuple = (0.4, 0.4, 0.05),  # base 기준 목표점 (x, y, z)
    d_max: float = 0.6,               # cube_align 이 0이 되는 3D 거리
    z_init: float = 0.025,            # 큐브 초기 높이 (현재 미사용, 참고용)
    dz_scale: float = 100.0,          # 변화량 스케일 (clamp(100*dz, 0, 10) 원리)
    dz_clip: float = 10.0,            # 변화량 보상 상한 (던지기 등 급격한 운동 억제)
) -> torch.Tensor:
    """단일 pick&place 보상.

        R = clamp(dz_scale * |z_t - z_{t-1}|, 0, dz_clip) * cube_align
        cube_align = clamp(1 - d_3D / d_max, 0, 1)

    - |z_t - z_{t-1}| : 큐브 z의 '절대 변화량'. 올라가든 내려가든 누적(곱해진 뒤 PPO가 시간 누적).
      → 큐브를 바닥에서 안 움직이면(밀기) 변화량 0 → 보상 0 (밀기 차단)
    - cube_align : 큐브가 목표점에 3D로 가까울수록 1 (clamp 원리)
      → 떠 있으면 z가 목표(0.035)와 멀어 align 감소 (던지기 억제)
    - clamp(.., 0, dz_clip) : 급격한 z 변화(던지기)의 스텝당 이득을 상한 → 폭발 방지

    주의(논의된 트레이드오프):
        변화량을 보상하므로 목표 근처에서 큐브를 미세하게 위아래로 '흔드는' 행동이
        창발할 수 있음. 텐서보드/시뮬에서 실제로 흔드는지 확인 필요.
    """
    global _prev_cube_z

    robot = env.scene["robot"]
    cube = env.scene[object_cfg.name]

    cube_rel = cube.data.root_state_w[:, :3] - robot.data.root_state_w[:, :3]
    x = cube_rel[:, 0]
    y = cube_rel[:, 1]
    z = cube_rel[:, 2]

    # 버퍼 초기화 (첫 호출 또는 env 수 변동 시)
    if _prev_cube_z is None or _prev_cube_z.shape[0] != z.shape[0]:
        _prev_cube_z = z.clone()

    # 절대 변화량
    dz = torch.abs(z - _prev_cube_z)

    # 에피소드 리셋 직후의 큐브 위치 점프(스파이크) 무시
    if hasattr(env, "episode_length_buf"):
        just_reset = env.episode_length_buf <= 1
        dz = torch.where(just_reset, torch.zeros_like(dz), dz)

    # 버퍼 갱신 (다음 스텝의 z_{t-1})
    _prev_cube_z = z.clone()

    # 변화량 항: 스케일 후 clamp 로 상한 (던지기 억제)
    dz_term = torch.clamp(dz_scale * dz, min=0.0, max=dz_clip)

    # cube_align: 목표점까지 3D 거리 기반 (clamp 원리)
    gx, gy, gz = goal
    d_3d = torch.sqrt((x - gx) ** 2 + (y - gy) ** 2 + (z - gz) ** 2)
    cube_align = torch.clamp(10*(1.0 - d_3d / d_max), min=0.0, max=10.0)

    return 1 * cube_align


def ee_pointing_down(
    env: ManagerBasedRLEnv,
    asset_cfg: SceneEntityCfg,) -> torch.Tensor:
    """link6의 로컬 +z축이 월드 아래(-z)를 향할수록 보상 (0~1)."""
    from isaaclab.utils.math import quat_apply

    asset = env.scene[asset_cfg.name]
    ee_quat = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]

    z_unit = torch.tensor([[0.0, 0.0, 1.0]], device=env.device).expand(env.num_envs, -1)
    ee_z = quat_apply(ee_quat, z_unit)

    align_down = -ee_z[:, 2]
    return torch.clamp(align_down, min=0.0, max=1.0)


def ee_to_cube_distance(env: ManagerBasedRLEnv, asset_cfg: SceneEntityCfg, object_cfg: SceneEntityCfg) -> torch.Tensor:
    from isaaclab.utils.math import quat_apply
    asset = env.scene[asset_cfg.name]
    cube  = env.scene[object_cfg.name]
    ee_pos  = asset.data.body_state_w[:, asset_cfg.body_ids[0], :3]
    ee_quat = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]
    local_offset = torch.tensor([[0.0, 0.0, 0.27]], device=ee_pos.device).expand(ee_pos.shape[0], -1)
    world_offset = quat_apply(ee_quat, local_offset)
    tcp_pos = ee_pos + world_offset
    cube_pos = cube.data.root_state_w[:, :3]
    distance = torch.norm(tcp_pos - cube_pos, dim=1)
    return 1.0 - torch.tanh(distance / 0.5)


def contact_penalty(env: ManagerBasedRLEnv, asset_cfg: SceneEntityCfg) -> torch.Tensor:
    """로봇 링크가 지면과 접촉하면 패널티"""
    asset = env.scene[asset_cfg.name]
    body_pos_z = asset.data.body_state_w[:, asset_cfg.body_ids, 2]
    contact = (body_pos_z < 0.1).any(dim=1).float()
    return contact


def ee_cube_axis_alignment(
    env: ManagerBasedRLEnv,
    asset_cfg: SceneEntityCfg,
    object_cfg: SceneEntityCfg,) -> torch.Tensor:
    """link6의 x,y축이 큐브의 x,y축과 일치할수록 보상"""
    from isaaclab.utils.math import quat_apply

    asset = env.scene[asset_cfg.name]
    cube  = env.scene[object_cfg.name]

    ee_quat   = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]
    cube_quat = cube.data.root_state_w[:, 3:7]

    x_unit = torch.tensor([[1.0, 0.0, 0.0]], device=env.device).expand(env.num_envs, -1)
    y_unit = torch.tensor([[0.0, 1.0, 0.0]], device=env.device).expand(env.num_envs, -1)

    ee_x   = quat_apply(ee_quat,   x_unit)
    ee_y   = quat_apply(ee_quat,   y_unit)
    cube_x = quat_apply(cube_quat, x_unit)
    cube_y = quat_apply(cube_quat, y_unit)

    align_x = torch.sum(ee_x * cube_x, dim=1)
    align_y = torch.sum(ee_y * cube_y, dim=1)

    reward = (torch.abs(align_x) + torch.abs(align_y)) / 2.0
    return reward

def dynamic_lift_reward(
    env: ManagerBasedRLEnv,
    object_cfg: SceneEntityCfg,
    target_pos: tuple = (0.4, 0.4, 0.05),
    radius: float = 0.1,
    z_init: float = 0.025
) -> torch.Tensor:
    """영역 밖에서는 Lift 권장, 영역 안에서는 Lift 페널티"""
    cube = env.scene[object_cfg.name]
    cube_pos = cube.data.root_state_w[:, :3]
    
    # 1. 목표와의 거리 계산 (GPU 텐서 매칭)
    target_tensor = torch.tensor(target_pos, device=cube_pos.device).expand(cube_pos.shape[0], -1)
    distance = torch.norm(cube_pos - target_tensor, dim=1)
    
    # 2. 반경 내 진입 여부 (True=1.0, False=0.0)
    is_inside = (distance < radius).float()
    
    # 3. Lift 높이 계산
    lift_height = cube_pos[:, 2] - z_init
    
    # 4. 조건에 따른 부호 스위칭 연산 (1 - 2 * is_inside)
    # 밖(0)이면 1.0, 안(1)이면 -1.0
    dynamic_multiplier = 1.0 - 2.0 * is_inside
    
    return lift_height * dynamic_multiplier

def dynamic_place_reward(
    env: ManagerBasedRLEnv,
    object_cfg: SceneEntityCfg,
    target_pos: tuple = (0.4, 0.4, 0.05),
    radius: float = 0.1,
) -> torch.Tensor:
    """목표점 도달 보상: 영역 안으로 들어오면 보상 스케일 10배 증가"""
    cube = env.scene[object_cfg.name]
    cube_pos = cube.data.root_state_w[:, :3]
    
    target_tensor = torch.tensor(target_pos, device=cube_pos.device).expand(cube_pos.shape[0], -1)
    distance = torch.norm(cube_pos - target_tensor, dim=1)
    
    is_inside = (distance < radius).float()
    
    # 거리가 가까울수록 1.0에 수렴하는 기본 보상
    base_reward = torch.exp(-distance / 0.1)
    
    # 밖(0)이면 1.0배, 안(1)이면 10.0배
    dynamic_weight = 1.0 + 9.0 * is_inside 
    
    return base_reward * dynamic_weight

def cube_xy_target_distance(
    env: ManagerBasedRLEnv,
    object_cfg: SceneEntityCfg,
    target_pos: tuple = (0.4, 0.4, 0.05),
    std: float = 0.1
) -> torch.Tensor:
    """큐브와 목표 위치 간의 XY 평면(2D) 거리 기반 보상"""
    cube = env.scene[object_cfg.name]
    
    # 1. 큐브의 현재 3D 위치 [x, y, z] 가져오기
    cube_pos = cube.data.root_state_w[:, :3]
    
    # 2. 목표 좌표를 텐서로 변환 (환경 수만큼 병렬 확장)
    target_tensor = torch.tensor(target_pos, device=cube_pos.device).expand(cube_pos.shape[0], -1)
    
    # 3. Z축을 제외하고 X, Y 성분만 추출 ([:, :2] 사용)
    cube_xy = cube_pos[:, :2]
    target_xy = target_tensor[:, :2]
    
    # 4. XY 평면 상의 유클리디안 거리 계산
    distance_xy = torch.norm(cube_xy - target_xy, dim=1)
    
    # 5. 거리가 가까울수록 1.0에 수렴하는 보상
    reward_xy = torch.exp(-distance_xy / std)
    
    return reward_xy

