@configclass
class ReachSceneCfg(InteractiveSceneCfg):
    ground = AssetBaseCfg(
        prim_path="/World/ground",
        spawn=sim_utils.GroundPlaneCfg(),
    )
    robot: ArticulationCfg = INDY7_CFG.replace(prim_path="{ENV_REGEX_NS}/Robot")
    cube = RigidObjectCfg(
        prim_path="{ENV_REGEX_NS}/Cube",
        spawn=sim_utils.CuboidCfg(
            size=(0.07, 0.07, 0.07),
            rigid_props=sim_utils.RigidBodyPropertiesCfg(),
            mass_props=sim_utils.MassPropertiesCfg(mass=0.1),
            collision_props=sim_utils.CollisionPropertiesCfg(),
            visual_material=sim_utils.PreviewSurfaceCfg(diffuse_color=(1.0, 0.0, 0.0)),
        ),
        init_state=RigidObjectCfg.InitialStateCfg(pos=(0.5, 0.0, 0.035)),
    )
    light = AssetBaseCfg(
        prim_path="/World/light",
        spawn=sim_utils.DomeLightCfg(color=(0.75, 0.75, 0.75), intensity=2500.0),
    )


@configclass
class ActionsCfg:
    arm_action = JointPositionActionCfg(
        asset_name="robot",
        joint_names=["joint[0-5]"],
        scale=0.5,
        use_default_offset=True,
    )
    gripper_action = JointPositionActionCfg(
        asset_name="robot",
        joint_names=["PrismaticJoint", "PrismaticJoint_finger1_b"],
        scale=1.0,
        use_default_offset=False,
    )


@configclass
class ObservationsCfg:
    @configclass
    class PolicyCfg(ObsGroup):
        joint_pos = ObsTerm(func=mdp.joint_pos_rel)
        joint_vel = ObsTerm(func=mdp.joint_vel_rel)
        ee_pos = ObsTerm(
            func=ee_position_w,
            params={"asset_cfg": SceneEntityCfg("robot", body_names=["link6"])},
        )
        cube_pos = ObsTerm(
            func=cube_position_w,
            params={"object_cfg": SceneEntityCfg("cube")},
        )
        gripper_pos = ObsTerm(
            func=mdp.joint_pos_rel,
            params={"asset_cfg": SceneEntityCfg("robot", joint_names=["PrismaticJoint", "PrismaticJoint_finger1_b"])},
        )

        def __post_init__(self):
            self.enable_corruption = False
            self.concatenate_terms = True

    policy: PolicyCfg = PolicyCfg()


@configclass
class RewardsCfg:
    # --- 유지: 접근 ---
    ee_to_cube = RewTerm(
        func=ee_to_cube_distance,
        weight=1.0,
        params={
            "asset_cfg": SceneEntityCfg("robot", body_names=["link6"]),
            "object_cfg": SceneEntityCfg("cube"),
        },
    )
    # --- 유지: 관절 속도 페널티 ---
    joint_vel_penalty = RewTerm(
        func=mdp.joint_vel_l2,
        weight=-0.001,
        params={"asset_cfg": SceneEntityCfg("robot")},
    )
    # --- 신규: 단일 pick&place 보상 (|Δz| × cube_align) ---
    pick_and_place = RewTerm(
        func=pick_and_place_reward,
        weight=3.0,   # 시작값. 텐서보드 보며 ee_to_cube(1.0) 대비 조정.
        params={
            "object_cfg": SceneEntityCfg("cube"),
            "goal": (0.4, 0.4, 0.035),
            "d_max": 0.6,
            "z_init": 0.025,
            "dz_scale": 100.0,
            "dz_clip": 10.0,
        },
    )
    # --- 유지: 지면 접촉 페널티 ---
    ground_contact = RewTerm(
        func=contact_penalty,
        weight=-2.0,
        params={
            "asset_cfg": SceneEntityCfg(
                "robot",
                body_names=["link6", "fingerhalf_01", "fingerhalf_02"]
            ),
        },
    )
    # --- 유지: 큐브 축 정렬 ---
    axis_align = RewTerm(
        func=ee_cube_axis_alignment,
        weight=0.5,
        params={
            "asset_cfg": SceneEntityCfg("robot", body_names=["link6"]),
            "object_cfg": SceneEntityCfg("cube"),
        },
    )
    # --- 유지: 아래 보기 ---
    ee_down = RewTerm(
        func=ee_pointing_down,
        weight=0.5,
        params={
            "asset_cfg": SceneEntityCfg("robot", body_names=["link6"]),
        },
    )


@configclass
class EventCfg:
    reset_all = EventTerm(func=mdp.reset_scene_to_default, mode="reset")
    reset_cube_position = EventTerm(
        func=mdp.reset_root_state_uniform,
        mode="reset",
        params={
            "pose_range": {"x": (0.1, 0.2), "y": (0.1, 0.2), "z": (0.025, 0.025)},
            "velocity_range": {},
            "asset_cfg": SceneEntityCfg("cube"),
        },
    )


@configclass
class TerminationsCfg:
    time_out = DoneTerm(func=mdp.time_out, time_out=True)


@configclass
class Indy7ReachEnvCfg(ManagerBasedRLEnvCfg):
    scene: ReachSceneCfg = ReachSceneCfg(num_envs=4096, env_spacing=3.0)
    actions: ActionsCfg = ActionsCfg()
    observations: ObservationsCfg = ObservationsCfg()
    rewards: RewardsCfg = RewardsCfg()
    events: EventCfg = EventCfg()
    terminations: TerminationsCfg = TerminationsCfg()

    def __post_init__(self):
        self.decimation = 4
        self.episode_length_s = 8.0
        self.sim.dt = 1.0 / 120.0
        self.sim.render_interval = self.decimation
        self.viewer.eye = (2.5, 2.5, 2.5)
