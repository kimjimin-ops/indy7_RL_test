def ee_position_w(env: ManagerBasedRLEnv, asset_cfg: SceneEntityCfg) -> torch.Tensor:
    from isaaclab.utils.math import quat_apply
    asset = env.scene[asset_cfg.name]
    ee_pos  = asset.data.body_state_w[:, asset_cfg.body_ids[0], :3]
    ee_quat = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]
    local_offset = torch.tensor([[0.0, 0.0, 0.27]], device=ee_pos.device).expand(ee_pos.shape[0], -1)
    world_offset = quat_apply(ee_quat, local_offset)
    tcp_pos = ee_pos + world_offset
    return tcp_pos - asset.data.root_state_w[:, :3]


def cube_position_w(env: ManagerBasedRLEnv, object_cfg: SceneEntityCfg) -> torch.Tensor:
    """Cube world position relative to robot base."""
    robot = env.scene["robot"]
    cube = env.scene[object_cfg.name]
    return cube.data.root_state_w[:, :3] - robot.data.root_state_w[:, :3]


def cube_lifted(env: ManagerBasedRLEnv, object_cfg: SceneEntityCfg, lift_threshold: float) -> torch.Tensor:
    """Reward: cube lifted above threshold height."""
    cube = env.scene[object_cfg.name]
    cube_z = cube.data.root_state_w[:, 2]
    return (cube_z > lift_threshold).float()


def ee_to_cube_distance(env: ManagerBasedRLEnv, asset_cfg: SceneEntityCfg, object_cfg: SceneEntityCfg) -> torch.Tensor:
    from isaaclab.utils.math import quat_apply
    asset = env.scene[asset_cfg.name]
    cube  = env.scene[object_cfg.name]
    ee_pos  = asset.data.body_state_w[:, asset_cfg.body_ids[0], :3]
    ee_quat = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]
    local_offset = torch.tensor([[0.0, 0.0, 0.27]], device=ee_pos.device).expand(ee_pos.shape[0], -1)
    world_offset = quat_apply(ee_quat, local_offset)
    tcp_pos = ee_pos + world_offset
    cube_pos = cube.data.root_state_w[:, :3]
    distance = torch.norm(tcp_pos - cube_pos, dim=1)
    return 1.0 - torch.tanh(distance / 0.5)


def contact_penalty(env: ManagerBasedRLEnv, asset_cfg: SceneEntityCfg) -> torch.Tensor:
    """로봇 링크가 지면과 접촉하면 패널티"""
    asset = env.scene[asset_cfg.name]
    body_pos_z = asset.data.body_state_w[:, asset_cfg.body_ids, 2]
    contact = (body_pos_z < 0.1).any(dim=1).float()
    return contact


def gripper_auto_reward(
    env: ManagerBasedRLEnv,
    asset_cfg: SceneEntityCfg,
    object_cfg: SceneEntityCfg,
    close_dist: float = 0.02,) -> torch.Tensor:
    """큐브 근처에서 닫힘, 멀면 열림 유도"""
    asset = env.scene[asset_cfg.name]
    cube  = env.scene[object_cfg.name]

    ee_pos   = asset.data.body_state_w[:, asset_cfg.body_ids[0], :3]
    cube_pos = cube.data.root_state_w[:, :3]
    dist     = torch.norm(ee_pos - cube_pos, dim=1)  # [num_envs]

    grip_pos = asset.data.joint_pos[:, -2:]  
    grip_avg = grip_pos.mean(dim=1)          

    near = (dist <= close_dist)
    target_grip = torch.where(near,
        torch.zeros_like(grip_avg),             
        torch.full_like(grip_avg, 0.015),       
    )
    
    grip_error = torch.abs(grip_avg - target_grip)
    return 1.0 - torch.tanh(grip_error / 0.005)


def ee_cube_axis_alignment(
    env: ManagerBasedRLEnv,
    asset_cfg: SceneEntityCfg,
    object_cfg: SceneEntityCfg,) -> torch.Tensor:
    """link6의 x,y축이 큐브의 x,y축과 일치할수록 보상"""
    from isaaclab.utils.math import quat_apply

    asset = env.scene[asset_cfg.name]
    cube  = env.scene[object_cfg.name]

    ee_quat   = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]
    cube_quat = cube.data.root_state_w[:, 3:7]

    x_unit = torch.tensor([[1.0, 0.0, 0.0]], device=env.device).expand(env.num_envs, -1)
    y_unit = torch.tensor([[0.0, 1.0, 0.0]], device=env.device).expand(env.num_envs, -1)

    ee_x   = quat_apply(ee_quat,   x_unit)  
    ee_y   = quat_apply(ee_quat,   y_unit)  
    cube_x = quat_apply(cube_quat, x_unit)  
    cube_y = quat_apply(cube_quat, y_unit)  

    align_x = torch.sum(ee_x * cube_x, dim=1)  
    align_y = torch.sum(ee_y * cube_y, dim=1)  

    reward = (torch.abs(align_x) + torch.abs(align_y)) / 2.0
    return reward


_cube_markers = None

def draw_cube_axes(env: ManagerBasedRLEnv, object_cfg: SceneEntityCfg) -> torch.Tensor:
    """큐브 중심점에 x,y,z 축 시각화"""
    from isaaclab.utils.math import quat_apply
    from isaaclab.markers import VisualizationMarkers, VisualizationMarkersCfg

    global _cube_markers

    cube = env.scene[object_cfg.name]
    num_envs = env.num_envs
    device = env.device

    if _cube_markers is None:
        marker_cfg = VisualizationMarkersCfg(
            prim_path="/Visuals/cube_axes",
            markers={
                "x_axis": sim_utils.CylinderCfg(
                    radius=0.35, height=0.7,
                    visual_material=sim_utils.PreviewSurfaceCfg(diffuse_color=(1.0, 0.0, 0.0)),
                ),
                "y_axis": sim_utils.CylinderCfg(
                    radius=0.35, height=0.7,
                    visual_material=sim_utils.PreviewSurfaceCfg(diffuse_color=(0.0, 1.0, 0.0)),
                ),
                "z_axis": sim_utils.CylinderCfg(
                    radius=0.35, height=0.7,
                    visual_material=sim_utils.PreviewSurfaceCfg(diffuse_color=(0.0, 0.0, 1.0)),
                ),
            },
        )
        _cube_markers = VisualizationMarkers(marker_cfg)

    cube_pos  = cube.data.root_state_w[:, :3]   
    cube_quat = cube.data.root_state_w[:, 3:7]  

    x_axis = torch.tensor([[0.05, 0.0, 0.0]], device=device).expand(num_envs, -1)
    y_axis = torch.tensor([[0.0, 0.05, 0.0]], device=device).expand(num_envs, -1)
    z_axis = torch.tensor([[0.0, 0.0, 0.05]], device=device).expand(num_envs, -1)

    x_pos = cube_pos + quat_apply(cube_quat, x_axis)
    y_pos = cube_pos + quat_apply(cube_quat, y_axis)
    z_pos = cube_pos + quat_apply(cube_quat, z_axis)

    q_x = torch.tensor([[0.7071, 0.0, -0.7071, 0.0]], device=device).expand(num_envs, -1)
    q_y = torch.tensor([[0.7071, 0.7071, 0.0, 0.0]], device=device).expand(num_envs, -1)
    q_z = torch.tensor([[1.0, 0.0, 0.0, 0.0]], device=device).expand(num_envs, -1)

    from isaaclab.utils.math import quat_mul
    q_x_world = quat_mul(cube_quat, q_x)
    q_y_world = quat_mul(cube_quat, q_y)
    q_z_world = quat_mul(cube_quat, q_z)

    translations = torch.cat([x_pos, y_pos, z_pos], dim=0)
    orientations = torch.cat([q_x_world, q_y_world, q_z_world], dim=0)
    marker_indices = torch.tensor(
        [0]*num_envs + [1]*num_envs + [2]*num_envs, device=device
    )

    _cube_markers.visualize(
        translations=translations,
        orientations=orientations,
        marker_indices=marker_indices,
    )

    return torch.zeros(num_envs, device=device)

