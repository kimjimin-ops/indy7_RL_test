def ee_position_w(env: ManagerBasedRLEnv, asset_cfg: SceneEntityCfg) -> torch.Tensor:
    from isaaclab.utils.math import quat_apply
    asset = env.scene[asset_cfg.name]
    ee_pos  = asset.data.body_state_w[:, asset_cfg.body_ids[0], :3]
    ee_quat = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]
    local_offset = torch.tensor([[0.0, 0.0, 0.27]], device=ee_pos.device).expand(ee_pos.shape[0], -1)
    world_offset = quat_apply(ee_quat, local_offset)
    tcp_pos = ee_pos + world_offset
    return tcp_pos - asset.data.root_state_w[:, :3]


def cube_position_w(env: ManagerBasedRLEnv, object_cfg: SceneEntityCfg) -> torch.Tensor:
    """Cube world position relative to robot base."""
    robot = env.scene["robot"]
    cube = env.scene[object_cfg.name]
    return cube.data.root_state_w[:, :3] - robot.data.root_state_w[:, :3]

def ee_to_cube_distance(env: ManagerBasedRLEnv, asset_cfg: SceneEntityCfg, object_cfg: SceneEntityCfg) -> torch.Tensor:
    from isaaclab.utils.math import quat_apply
    asset = env.scene[asset_cfg.name]
    cube  = env.scene[object_cfg.name]
    ee_pos  = asset.data.body_state_w[:, asset_cfg.body_ids[0], :3]
    ee_quat = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]
    local_offset = torch.tensor([[0.0, 0.0, 0.27]], device=ee_pos.device).expand(ee_pos.shape[0], -1)
    world_offset = quat_apply(ee_quat, local_offset)
    tcp_pos = ee_pos + world_offset
    cube_pos = cube.data.root_state_w[:, :3]
    distance = torch.norm(tcp_pos - cube_pos, dim=1)
    return 1.0 - torch.tanh(distance / 0.5)

def contact_penalty(env: ManagerBasedRLEnv, asset_cfg: SceneEntityCfg) -> torch.Tensor:
    """로봇 링크가 지면과 접촉하면 패널티"""
    asset = env.scene[asset_cfg.name]
    body_pos_z = asset.data.body_state_w[:, asset_cfg.body_ids, 2]
    contact = (body_pos_z < 0.1).any(dim=1).float()
    return contact

def gripper_auto_reward(
    env: ManagerBasedRLEnv,
    asset_cfg: SceneEntityCfg,
    object_cfg: SceneEntityCfg,
    close_dist: float = 0.02,) -> torch.Tensor:
    """큐브 근처(2cm 이하)에서 닫힘, 멀면 열림 유도"""
    asset = env.scene[asset_cfg.name]
    cube  = env.scene[object_cfg.name]

    # EE와 큐브 거리
    ee_pos   = asset.data.body_state_w[:, asset_cfg.body_ids[0], :3]
    cube_pos = cube.data.root_state_w[:, :3]
    dist     = torch.norm(ee_pos - cube_pos, dim=1)  # [num_envs]

    # 그리퍼 현재 상태 (PrismaticJoint 2개 평균)
    grip_pos = asset.data.joint_pos[:, -2:]  # 마지막 2개 = 그리퍼
    grip_avg = grip_pos.mean(dim=1)          # [num_envs]

    # 가까울 때(≤2cm): 닫힘(0.0)에 가까울수록 보상
    # 멀 때(>2cm):     열림(0.015)에 가까울수록 보상
    near = (dist <= close_dist)
    target_grip = torch.where(near,
        torch.zeros_like(grip_avg),             # 닫힘 목표
        torch.full_like(grip_avg, 0.015),       # 열림 목표
    )
    
    grip_error = torch.abs(grip_avg - target_grip)
    return 1.0 - torch.tanh(grip_error / 0.005)

def ee_cube_axis_alignment(
    env: ManagerBasedRLEnv,
    asset_cfg: SceneEntityCfg,
    object_cfg: SceneEntityCfg,) -> torch.Tensor:
    """link6의 x,y축이 큐브의 x,y축과 일치할수록 보상"""
    from isaaclab.utils.math import quat_apply

    asset = env.scene[asset_cfg.name]
    cube  = env.scene[object_cfg.name]

    # link6와 큐브의 quaternion
    ee_quat   = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]
    cube_quat = cube.data.root_state_w[:, 3:7]

    # 각 좌표계의 x, y 단위벡터 추출
    x_unit = torch.tensor([[1.0, 0.0, 0.0]], device=env.device).expand(env.num_envs, -1)
    y_unit = torch.tensor([[0.0, 1.0, 0.0]], device=env.device).expand(env.num_envs, -1)

    ee_x   = quat_apply(ee_quat,   x_unit)  # link6 x축 방향
    ee_y   = quat_apply(ee_quat,   y_unit)  # link6 y축 방향
    cube_x = quat_apply(cube_quat, x_unit)  # 큐브 x축 방향
    cube_y = quat_apply(cube_quat, y_unit)  # 큐브 y축 방향

    # 내적: 두 벡터가 같은 방향이면 1.0, 반대면 -1.0
    align_x = torch.sum(ee_x * cube_x, dim=1)  # [num_envs]
    align_y = torch.sum(ee_y * cube_y, dim=1)  # [num_envs]

    # 절댓값: 180도 반대여도 같은 축 방향으로 허용
    reward = (torch.abs(align_x) + torch.abs(align_y)) / 2.0
    return reward

def is_cube_align(
    env: ManagerBasedRLEnv,
    object_cfg: SceneEntityCfg,
    place_xy: tuple = (0.4, 0.4),
    radius: float = 0.15,
) -> torch.Tensor:
    robot = env.scene["robot"]
    cube = env.scene[object_cfg.name]
    cube_rel = cube.data.root_state_w[:, :3] - robot.data.root_state_w[:, :3]  # 베이스 기준
    d_xy = torch.sqrt(
        (cube_rel[:, 0] - place_xy[0]) ** 2 + (cube_rel[:, 1] - place_xy[1]) ** 2
    )
    return (d_xy <= radius).float()

def R_pick_place(
    env: ManagerBasedRLEnv,
    asset_cfg: SceneEntityCfg,
    object_cfg: SceneEntityCfg,
    place_xy: tuple = (0.4, 0.4),
    radius: float = 0.15,
    distance_threshold: float = 0.1,
    z_init: float = 0.025,
    lift_gate: float = 5.0,          # 5cm 이상 들면 latch 켜짐
) -> torch.Tensor:
    from isaaclab.utils.math import quat_apply
    asset = env.scene[asset_cfg.name]
    cube = env.scene[object_cfg.name]

    # --- latch 텐서 최초 1회 생성 ---
    if not hasattr(env, "lift_latched"):
        env.lift_latched = torch.zeros(env.num_envs, dtype=torch.bool, device=env.device)

    # TCP 위치
    ee_pos = asset.data.body_state_w[:, asset_cfg.body_ids[0], :3]
    ee_quat = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]
    local_offset = torch.tensor([[0.0, 0.0, 0.27]], device=ee_pos.device).expand(ee_pos.shape[0], -1)
    tcp_pos = ee_pos + quat_apply(ee_quat, local_offset)

    cube_pos = cube.data.root_state_w[:, :3]

    distance = torch.norm(tcp_pos - cube_pos, dim=1)
    is_close = (distance < distance_threshold).float()

    h = cube_pos[:, 2] - z_init
    is_lifted = (h >= 0.01).float()

    align = is_cube_align(env, object_cfg, place_xy, radius)

    lift_up = torch.clamp(100.0 * h, min=0.0, max=10.0)
    lift_down = torch.clamp(100.0 * h, min=1.0, max=10.0)

    # --- latch 갱신: 한 번 켜지면 에피소드 끝까지 유지 ---
    R_lift = is_close * is_lifted * lift_up
    env.lift_latched = env.lift_latched | (R_lift >= lift_gate)
    R_lift_result = env.lift_latched.float()

    reward_out = is_close * is_lifted * lift_up * (1.0 - align)
    reward_in = is_close * is_lifted * (20.0 - lift_down) * align * R_lift_result
    return reward_out + reward_in





def cube_xy_target_distance(
    env: ManagerBasedRLEnv,
    object_cfg: SceneEntityCfg,
    target_pos: tuple = (0.4, 0.4, 0.05),
    std: float = 0.1
) -> torch.Tensor:
    robot = env.scene["robot"]
    cube = env.scene[object_cfg.name]

    # 베이스 기준 상대 좌표로 통일
    cube_pos = cube.data.root_state_w[:, :3] - robot.data.root_state_w[:, :3]

    target_tensor = torch.tensor(target_pos, device=cube_pos.device).expand(cube_pos.shape[0], -1)
    cube_xy = cube_pos[:, :2]
    target_xy = target_tensor[:, :2]

    distance_xy = torch.norm(cube_xy - target_xy, dim=1)
    reward_xy = torch.exp(-distance_xy / std)
    return reward_xy

def ee_pointing_down(
    env: ManagerBasedRLEnv,
    asset_cfg: SceneEntityCfg,) -> torch.Tensor:
    """link6의 로컬 +z축이 월드 아래(-z)를 향할수록 보상 (0~1)."""
    from isaaclab.utils.math import quat_apply

    asset = env.scene[asset_cfg.name]
    ee_quat = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]

    z_unit = torch.tensor([[0.0, 0.0, 1.0]], device=env.device).expand(env.num_envs, -1)
    ee_z = quat_apply(ee_quat, z_unit)

    align_down = -ee_z[:, 2]
    return torch.clamp(align_down, min=0.0, max=1.0)

def reset_lift_latch(env, env_ids,):
    if hasattr(env, "lift_latched"):
        env.lift_latched[env_ids] = False


