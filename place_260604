def conditional_cube_place(
    env: ManagerBasedRLEnv, 
    asset_cfg: SceneEntityCfg,   # 로봇 EE
    object_cfg: SceneEntityCfg,  # 큐브
    target_cfg: SceneEntityCfg,  # 타겟 B점
    distance_threshold: float,   # 그리퍼-큐브 밀착 기준 거리
    xy_tolerance: float,         # B점 도달 판정 기준 반경 (예: 5cm)
    z_init: float) -> torch.Tensor:
    from isaaclab.utils.math import quat_apply
    
    asset = env.scene[asset_cfg.name]
    cube = env.scene[object_cfg.name]
    target = env.scene[target_cfg.name]
    
    # 1. EE TCP 위치 계산 및 큐브 그랩 여부 확인
    ee_pos = asset.data.body_state_w[:, asset_cfg.body_ids[0], :3]
    ee_quat = asset.data.body_state_w[:, asset_cfg.body_ids[0], 3:7]
    local_offset = torch.tensor([[0.0, 0.0, 0.27]], device=ee_pos.device).expand(ee_pos.shape[0], -1)
    tcp_pos = ee_pos + quat_apply(ee_quat, local_offset)
    
    cube_pos = cube.data.root_state_w[:, :3]
    is_grabbed = torch.norm(tcp_pos - cube_pos, dim=1) < distance_threshold
    
    # 2. 높이 h 및 B점과의 xy 평면 거리 계산
    h = torch.clamp(cube_pos[:, 2] - z_init, min=0.0)
    target_pos = target.data.root_state_w[:, :3]
    xy_dist = torch.norm(cube_pos[:, :2] - target_pos[:, :2], dim=1)
    
    # 3. 제안하신 지수 조건 분기
    is_far = xy_dist > xy_tolerance      # 5cm 밖 (지수 x = 1 역할)
    is_close_xy = xy_dist <= xy_tolerance # 5cm 안 (지수 x = -1 역할)
    
    # 5cm 밖: 기존처럼 들어올릴수록 보상 증가 (최대 10 제한)
    reward_lift = is_far.float() * torch.clamp(h * 100.0, min=0.0, max=10.0)
    
    # 5cm 안: 지면에 가까워질수록 보상 폭발적 증가 (h+0.01 역수 활용)
    # h가 0에 근접하면 (0.01)^-1 = 100. 여기에 100을 곱해 최대 10000 달성
    reward_place = is_close_xy.float() * (100.0 * torch.pow(h + 0.01, -1.0))
    
    # 4. 큐브를 잡고 있을 때만 보상 부여 (초기 꼼수 방지)
    return is_grabbed.float() * (reward_lift + reward_place)    
